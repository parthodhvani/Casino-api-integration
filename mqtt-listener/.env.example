# Copy this file to .env and fill in the values.
# DO NOT commit the real .env file.

# --- MQTT (HiveMQ) ---
MQTT_HOST=699e47e0f3cc47a58a4da1fbeff8f089.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=drgt.drTv
MQTT_PASSWORD=drTv1234
# One topic, or a comma-separated list for future topics: /jp/gent,/jp/berck
MQTT_TOPIC=/jp/gent

# Optional MQTT tuning (safe defaults shown)
# MQTT_RECONNECT_MS=5000
# MQTT_CONNECT_TIMEOUT_MS=30000

# --- Cloudflare Worker ---
# Your deployed worker URL (e.g. https://jackpot-worker.<subdomain>.workers.dev)
WORKER_URL=https://jackpot-worker.example.workers.dev

# Must match the LISTENER_SECRET set on the Worker (wrangler secret put LISTENER_SECRET)
LISTENER_SECRET=replace-with-a-random-string

# Optional forwarding tuning (safe defaults shown)
# WORKER_RETRIES=3
# WORKER_TIMEOUT_MS=8000
# WORKER_BACKOFF_MS=500

# --- Runtime ---
# Heartbeat log interval (ms)
# HEARTBEAT_MS=60000
# Optional dead-man's-switch URL pinged after each successful forward
# HEALTHCHECK_URL=
