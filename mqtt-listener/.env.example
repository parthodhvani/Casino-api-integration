# --- HTTP control API ---
# CONTROL_HOST=0.0.0.0
# CONTROL_PORT=3099

# --- Daily MQTT schedule ---
# SCHEDULE_ENABLED=true
# SCHEDULE_START=06:00
# SCHEDULE_STOP=08:00
# SCHEDULE_TZ=Europe/Paris
# MQTT_AUTO_START=false

# --- Runtime ---
# HEARTBEAT_MS=60000
# HEALTHCHECK_URL=
# WORKER_RETRIES=3
# WORKER_TIMEOUT_MS=8000
# WORKER_BACKOFF_MS=500
