# Compatible with Node.js 14+ (cPanel + LiteSpeed).
# Copy this file to .env and fill in the values.
# On cPanel Node.js App, set these in the Environment Variables UI instead.
# DO NOT commit the real .env file.

# --- MQTT (HiveMQ) ---
MQTT_HOST=699e47e0f3cc47a58a4da1fbeff8f089.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=drgt.drTv
MQTT_PASSWORD=drTv1234
MQTT_TOPIC=/jp/gent

# --- WordPress destinations (HMAC with JACKPOT_SECRET) ---
# JSON array. Example:
# WP_SITES=[{"name":"casinoberck","url":"https://www.example.com/wp-json/jackpot/v1/update"}]
WP_SITES=
JACKPOT_SECRET=replace-with-shared-secret
LISTENER_SECRET=replace-with-a-random-string

# --- HTTP control API / LiteSpeed ---
# Default (cPanel LiteSpeed): leave BIND_MODE unset → bare server.listen()
# Do NOT set CONTROL_HOST=0.0.0.0 on LiteSpeed (causes 503).
# For local/dev only:
# BIND_MODE=explicit
# CONTROL_HOST=127.0.0.1
# CONTROL_PORT=3099

# --- Daily MQTT schedule ---
# SCHEDULE_ENABLED=true
# SCHEDULE_START=06:00
# SCHEDULE_STOP=08:00
# SCHEDULE_TZ=Europe/Paris
# MQTT_AUTO_START=false

# --- Runtime / forward tuning ---
# HEARTBEAT_MS=60000
# HEALTHCHECK_URL=
# FORWARD_RETRIES=3
# FORWARD_TIMEOUT_MS=8000
# FORWARD_BACKOFF_MS=500
